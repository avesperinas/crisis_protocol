# Plantilla para despliegue en producción (docker-compose.prod.yml lee
# backend/.env vía env_file). Copia esto a backend/.env y rellena los valores
# reales — nunca commitees ese archivo (ya está en .gitignore).
#
# Ver backend/src/config.py para la lista completa de variables soportadas
# y sus valores por defecto.

ANTHROPIC_API_KEY=

# IMPORTANTE: el valor por defecto en config.py es
# "dev-insecure-secret-change-in-production" — literalmente eso, sin cifrar.
# Genera uno propio antes de desplegar, p. ej.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=

# Opcional — solo si quieres forzar Haiku en todas las llamadas a Claude
# (más barato, útil para staging/pruebas de carga).
HAIKU_ONLY=false
